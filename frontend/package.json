  },
  "dependencies": {
    "@wailsio/runtime": "latest",
    "lucide-vue-next": "^1.0.0",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.10",
    "prettier": "^3.7.0",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.5"
  }
}
