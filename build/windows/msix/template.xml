<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="wingsv_dex"
        Arguments=""
        InstallLocation="C:\Program Files\WINGS-N\WINGS V Dex">
    </Installer>
    <PackageInformation
        PackageName="WINGS V Dex"
        PackageDisplayName="WINGS V Dex"
        PublisherName="CN=WINGS-N"
        PublisherDisplayName="WINGS-N"
        Version="0.1.0.0"
        PackageDescription="WINGS V desktop client (VK TURN)">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="org.wingsnet.dex"
                Description="WINGS V desktop client (VK TURN)"
                DisplayName="WINGS V Dex"
                ExecutableName="wingsv_dex"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>WINGS V Dex</DisplayName>
            <PublisherDisplayName>WINGS-N</PublisherDisplayName>
            <Description>WINGS V desktop client (VK TURN)</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="wingsv_dex.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
