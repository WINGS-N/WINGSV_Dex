# Maintainer: WINGS-N <https://github.com/WINGS-N>
#
# The stable release, built from source:
#   git clone https://github.com/WINGS-N/WINGSV_DeX
#   cd WINGSV_DeX/build/linux/aur/wingsv-dex && makepkg -si
# Siblings: wingsv-dex-git builds the current main, wingsv-dex-bin takes the
# prebuilt release tarball.
#
# pkgver tracks the newest release tag; build/linux/aur/update-pkgbuild.sh moves it.
# The source is the git tag rather than GitHub's generated tarball because that
# tarball omits submodules, and the build needs them.

pkgname=wingsv-dex
pkgver=0.2.0
pkgrel=1
pkgdesc="VPN client that hides WireGuard inside VK calls (VK TURN)"
arch=('x86_64' 'aarch64')
url="https://github.com/WINGS-N/WINGSV_DeX"
license=('GPL-3.0-or-later')
# GTK4 and WebKitGTK are deliberately not vendored: WebKitGTK spawns its helper
# processes from a path baked in at compile time, so it has to be the system one.
depends=('gtk4' 'webkitgtk-6.0' 'nftables')
optdepends=('polkit: privilege elevation when bringing the VPN up')
makedepends=('go' 'nodejs' 'pnpm' 'git')
conflicts=('wingsv-dex-git' 'wingsv-dex-bin')
options=('!strip' '!lto')
source=("$pkgname-$pkgver::git+$url.git#tag=v$pkgver")
sha256sums=('SKIP')

prepare() {
  cd "$pkgname-$pkgver"
  git submodule update --init --recursive
  # wails3 generates the frontend bindings; keep it out of the user's GOPATH.
  export GOPATH="$srcdir/gopath"
  go install github.com/wailsapp/wails/v3/cmd/wails3@v3.0.0-alpha2.113
}

build() {
  cd "$pkgname-$pkgver"
  export GOPATH="$srcdir/gopath"
  export PATH="$GOPATH/bin:$PATH"
  export CGO_CPPFLAGS="${CPPFLAGS}" CGO_CFLAGS="${CFLAGS}" CGO_LDFLAGS="${LDFLAGS}"

  pnpm --dir frontend install --frozen-lockfile
  wails3 generate bindings -clean=true -time-type=Date
  pnpm --dir frontend build

  mkdir -p bin
  # The GUI needs cgo for GTK/WebKit; the three helpers are static and do not.
  go build -trimpath -ldflags="-s -w" -o bin/wingsv-dex .
  (cd external/vk-turn-proxy && CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o "$srcdir/$pkgname-$pkgver/bin/vkturn" ./client)
  (cd cmd/xrayhelper && CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o "$srcdir/$pkgname-$pkgver/bin/xray" .)
  (cd external/byedpi && make && cp ciadpi "$srcdir/$pkgname-$pkgver/bin/byedpi")
}

package() {
  cd "$pkgname-$pkgver"
  # The app resolves xray/byedpi/vkturn next to its own executable, so they all
  # live in one private directory and /usr/bin gets a symlink. os.Executable()
  # resolves /proc/self/exe, so launching through the symlink still finds them.
  install -Dm755 bin/wingsv-dex "$pkgdir/usr/lib/wingsv-dex/wingsv-dex"
  install -Dm755 bin/vkturn "$pkgdir/usr/lib/wingsv-dex/vkturn"
  install -Dm755 bin/xray "$pkgdir/usr/lib/wingsv-dex/xray"
  install -Dm755 bin/byedpi "$pkgdir/usr/lib/wingsv-dex/byedpi"
  install -d "$pkgdir/usr/bin"
  ln -s /usr/lib/wingsv-dex/wingsv-dex "$pkgdir/usr/bin/wingsv-dex"

  install -Dm644 build/linux/wingsv-dex.desktop "$pkgdir/usr/share/applications/wingsv-dex.desktop"
  install -Dm644 build/appicon.png "$pkgdir/usr/share/icons/hicolor/512x512/apps/wingsv-dex.png"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
